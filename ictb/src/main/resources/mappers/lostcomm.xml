<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.co.ictb.ictb.dao.LostCommDao">
	<insert id="addLostComm" parameterType="lostcommvo">
		INSERT INTO lost_comments VALUES(lost_comm_seq.nextval, #{lnum}, #{mnum}, #{writer}, #{content}, SYSDATE)
	</insert>
	
	<select id="listLostComment" resultType="lostcommvo" parameterType="int">
		SELECT * FROM lost_comments WHERE LNUM = #{lnum} ORDER BY lcnum ASC
	</select>
	
	<delete id="lostcommdelete" parameterType="int">
		DELETE FROM lost_comments where LCNUM = #{lcnum}
	</delete>
	
	<update id="lostcommupdate" parameterType="map">
		UPDATE lost_comments SET content = #{content}, lcdate = SYSDATE WHERE lcnum = #{lcnum}
	</update>
</mapper>